{
  "uid": "nebulaops-overview",
  "title": "NebulaOps Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP Requests / min",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 Latency by Service",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, application))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "JVM Memory Used",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes) by (application, area)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Kafka Task Events Produced",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(kafka_producer_record_send_total)",
          "refId": "A"
        }
      ]
    }
  ]
}
