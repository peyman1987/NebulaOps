  "panels": [
    {
      "type": "stat",
      "title": "Gateway up",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "up{job=\"gateway-service\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Services up",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(up)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Scrape health by service",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "up"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (job)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM memory used",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(jvm_memory_used_bytes) by (job, area)"
        }
      ]
    }
  ]
}