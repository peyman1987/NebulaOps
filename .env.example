DB_USER=nebula
DB_PASSWORD=nebula
JWT_SECRET=change-me-change-me-change-me-change-me-123456
AWS_REGION=eu-south-1
S3_BUCKET=nebulaops-files-demo

# ── Runtime identity / auth (v22.5) ───────────────────────────
COMPOSE_PROJECT_NAME=nebulaops-v22-5
NEBULAOPS_PUBLIC_URL=http://nebulaops.localhost
NEBULAOPS_HTTP_PORT=80
KEYCLOAK_CLIENT_SECRET=nebulaops-secret-dev-only
KEYCLOAK_AUTH_ENABLED=true
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/nebulaops/protocol/openid-connect/certs
GITLAB_ROOT_PASSWORD=NebulaOpsRoot22!
GITLAB_OIDC_CLIENT_SECRET=gitlab-secret-dev-only
# Keycloak OAuth clients (development secrets only)
KEYCLOAK_REALM=nebulaops
KEYCLOAK_PUBLIC_URL=http://nebulaops.localhost/keycloak
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_FRONTEND_CLIENT_ID=nebulaops-frontend
KEYCLOAK_GATEWAY_CLIENT_ID=nebulaops-gateway
KEYCLOAK_GATEWAY_CLIENT_SECRET=nebulaops-secret-dev-only
GRAFANA_OAUTH_CLIENT_SECRET=grafana-secret-dev-only
OAUTH2_PROXY_CLIENT_SECRET=oauth2-proxy-secret-dev-only

# Optional heavy local GitLab CE runtime. Disabled by default.
GITLAB_ENABLED=false
GITLAB_URL=
# Enable the Docker Compose profile only when needed: COMPOSE_PROFILES=gitlab

# Host port for direct Grafana access. Internal container port remains 3000.
GRAFANA_HOST_PORT=3300


# Real LLM provider for ai-engine. Leave blank to return explicit LLM_UNAVAILABLE fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TIMEOUT_SECONDS=20
